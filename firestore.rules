rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function authEmail() {
      return isSignedIn() && request.auth.token.email is string
        ? request.auth.token.email.lower()
        : "";
    }

    function isBootstrapAdmin() {
      return isSignedIn() &&
        authEmail() in [
          "alekcaballeromusic@gmail.com",
          "catalina.medina.leal@gmail.com",
          "imusicala@gmail.com"
        ];
    }

    function hasAccessProfile() {
      return authEmail() != "" &&
        exists(/databases/$(database)/documents/users/$(authEmail()));
    }

    function accessProfile() {
      return get(/databases/$(database)/documents/users/$(authEmail()));
    }

    function accessRole() {
      return hasAccessProfile() && accessProfile().data.role is string
        ? accessProfile().data.role
        : "";
    }

    function accessIsActive() {
      return hasAccessProfile()
        ? accessProfile().data.active != false
        : false;
    }

    function linkedStudentId() {
      return hasAccessProfile() && accessProfile().data.studentId is string
        ? accessProfile().data.studentId
        : (
            hasAccessProfile() && accessProfile().data.studentKey is string
            ? accessProfile().data.studentKey
            : ""
          );
    }

    function hasCatalogs() {
      return exists(/databases/$(database)/documents/app_config/catalogos);
    }

    function teacherEmailList() {
      return hasCatalogs() &&
        get(/databases/$(database)/documents/app_config/catalogos).data.teacherAccessEmails is list
        ? get(/databases/$(database)/documents/app_config/catalogos).data.teacherAccessEmails
        : [];
    }

    function isAdmin() {
      return isBootstrapAdmin() || (accessRole() == "admin" && accessIsActive());
    }

    function teacherProfilePath() {
      return /databases/$(database)/documents/teacherProfiles/$(request.auth.uid);
    }

    function hasTeacherProfile() {
      return isSignedIn() && exists(teacherProfilePath());
    }

    function teacherProfile() {
      return get(teacherProfilePath()).data;
    }

    function teacherProfileIsActive() {
      return hasTeacherProfile() && teacherProfile().active != false;
    }

    function isTeacherAdmin() {
      return isAdmin()
        || (accessRole() == "lider" && accessIsActive())
        || (
          teacherProfileIsActive()
          && (
            (
              teacherProfile().role is string
              && teacherProfile().role in ["admin", "lider"]
            )
            || (
              teacherProfile().roles is list
              && teacherProfile().roles.hasAny(["admin", "lider"])
            )
          )
        );
    }

    function canAccessArea(areaId) {
      return isTeacherAdmin()
        || (
          hasAccessProfile()
          && accessIsActive()
          && accessProfile().data.areaIds is list
          && areaId in accessProfile().data.areaIds
        )
        || (
          hasAccessProfile()
          && accessIsActive()
          && accessProfile().data.areaId is string
          && areaId == accessProfile().data.areaId
        )
        || (authEmail() == "eryck1214@gmail.com" && areaId == "danzas")
        || (authEmail() == "natymoreno10@gmail.com" && areaId == "porras")
        || (
          teacherProfileIsActive()
          && teacherProfile().areaIds is list
          && areaId in teacherProfile().areaIds
        );
    }

    function isTeacher() {
      return (accessRole() == "teacher" && accessIsActive()) ||
        (authEmail() != "" && authEmail() in teacherEmailList()) ||
        teacherProfileIsActive();
    }

    function isActiveStudent() {
      return accessRole() == "student" &&
        accessIsActive() &&
        linkedStudentId() != "";
    }

    function studentOwnsBitacora() {
      return isActiveStudent() &&
        resource.data.studentIds is list &&
        linkedStudentId() in resource.data.studentIds;
    }

    function studentOwnsStudentDoc() {
      return isActiveStudent() &&
        (
          resource.id == linkedStudentId() ||
          (resource.data.studentId is string && resource.data.studentId == linkedStudentId()) ||
          (resource.data.studentKey is string && resource.data.studentKey == linkedStudentId())
        );
    }

    match /users/{emailKey} {
      allow read: if isAdmin() || (isSignedIn() && authEmail() == emailKey);
      allow create, update, delete: if isAdmin();
    }

    match /teacherProfiles/{uid} {
      allow read: if isTeacherAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow create, update, delete: if isTeacherAdmin();
    }

    match /app_config/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /bitacoras/{bitacoraId} {
      allow read: if isAdmin() || isTeacher() || studentOwnsBitacora();
      allow create, update, delete: if isAdmin() || isTeacher();
    }

    match /student_routes/{studentId} {
      allow read: if isAdmin() || isTeacher() ||
        (isActiveStudent() && linkedStudentId() == studentId);
      allow create, update, delete: if isAdmin() || isTeacher();
    }

    match /students/{studentId} {
      allow read: if isAdmin() || isTeacher() || studentOwnsStudentDoc() || canAccessArea(resource.data.areaId);
      allow create: if isAdmin() || (
        isSignedIn()
        && canAccessArea(request.resource.data.areaId)
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.teacherEmail == authEmail()
      );
      allow update: if isAdmin() || (
        isSignedIn()
        && canAccessArea(resource.data.areaId)
        && canAccessArea(request.resource.data.areaId)
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.teacherEmail == authEmail()
      );
      allow delete: if isAdmin();
    }

    match /teacherShifts/{shiftId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.teacherEmail == authEmail();
      allow update: if isTeacherAdmin()
        || (
          isSignedIn()
          && resource.data.teacherId == request.auth.uid
          && resource.data.teacherEmail == authEmail()
        );
      allow delete: if isTeacherAdmin();
    }

    match /attendanceSessions/{attendanceId} {
      allow read: if isSignedIn() && canAccessArea(resource.data.areaId);
      allow create: if isSignedIn()
        && canAccessArea(request.resource.data.areaId)
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.teacherEmail == authEmail();
      allow update: if isSignedIn()
        && canAccessArea(resource.data.areaId)
        && canAccessArea(request.resource.data.areaId)
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.teacherEmail == authEmail();
      allow delete: if isTeacherAdmin();
    }

    match /classLogs/{logId} {
      allow read: if isSignedIn() && canAccessArea(resource.data.areaId);
      allow create: if isSignedIn()
        && canAccessArea(request.resource.data.areaId)
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.teacherEmail == authEmail();
      allow update: if isSignedIn()
        && canAccessArea(resource.data.areaId)
        && canAccessArea(request.resource.data.areaId)
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.teacherEmail == authEmail();
      allow delete: if isTeacherAdmin();
    }

    match /diagnosticos/{recordId} {
      allow read: if isSignedIn() && canAccessArea(resource.data.areaId);
      allow create: if isSignedIn()
        && canAccessArea(request.resource.data.areaId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == authEmail()
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.teacherEmail == authEmail();
      allow update: if isSignedIn()
        && canAccessArea(resource.data.areaId)
        && canAccessArea(request.resource.data.areaId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == authEmail()
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.teacherEmail == authEmail();
      allow delete: if isTeacherAdmin();
    }

    match /proyectos/{recordId} {
      allow read: if isSignedIn() && canAccessArea(resource.data.areaId);
      allow create: if isSignedIn()
        && canAccessArea(request.resource.data.areaId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == authEmail()
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.teacherEmail == authEmail();
      allow update: if isSignedIn()
        && canAccessArea(resource.data.areaId)
        && canAccessArea(request.resource.data.areaId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == authEmail()
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.teacherEmail == authEmail();
      allow delete: if isTeacherAdmin();
    }

    match /muestrasProceso/{recordId} {
      allow read: if isSignedIn() && canAccessArea(resource.data.areaId);
      allow create: if isSignedIn()
        && canAccessArea(request.resource.data.areaId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == authEmail()
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.teacherEmail == authEmail();
      allow update: if isSignedIn()
        && canAccessArea(resource.data.areaId)
        && canAccessArea(request.resource.data.areaId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == authEmail()
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.teacherEmail == authEmail();
      allow delete: if isTeacherAdmin();
    }

    match /informesMensuales/{recordId} {
      allow read: if isSignedIn() && canAccessArea(resource.data.areaId);
      allow create: if isSignedIn()
        && canAccessArea(request.resource.data.areaId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == authEmail()
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.teacherEmail == authEmail();
      allow update: if isSignedIn()
        && canAccessArea(resource.data.areaId)
        && canAccessArea(request.resource.data.areaId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == authEmail()
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.teacherEmail == authEmail();
      allow delete: if isTeacherAdmin();
    }

    match /leaderSchedules/{scheduleId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isTeacherAdmin();
    }

    match /hubSettings/{settingId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isTeacherAdmin();
    }

    match /calendarEvents/{eventId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isTeacherAdmin();
    }

    match /calendar2026/{eventId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isTeacherAdmin();
    }

    match /galleryImages/{galleryId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isTeacherAdmin();
    }
  }
}
