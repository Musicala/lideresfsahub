rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return signedIn() && request.auth.token.email != null
        ? request.auth.token.email.lower()
        : '';
    }

    function isCurrentUser(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function canUseAllAreas() {
      return userEmail() in [
        'alekcaballeromusic@gmail.com',
        'catalina.medina.leal@gmail.com'
      ];
    }

    function isAdmin() {
      return canUseAllAreas();
    }

    function canAccessArea(areaId) {
      return canUseAllAreas()
        || (userEmail() == 'eryck1214@gmail.com' && areaId == 'danzas')
        || (userEmail() == 'natymoreno10@gmail.com' && areaId == 'porras');
    }

    match /teacherProfiles/{uid} {
      allow read: if isCurrentUser(uid) || isAdmin() || signedIn();
      allow create, update: if isCurrentUser(uid)
        && request.resource.data.email == userEmail();
    }

    match /leaderSchedules/{scheduleId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /hubSettings/{settingId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /calendarEvents/{eventId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /calendar2026/{eventId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /teacherShifts/{shiftId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.teacherEmail == userEmail();
      allow update: if signedIn()
        && resource.data.teacherId == request.auth.uid
        && resource.data.teacherEmail == userEmail();
    }

    match /students/{studentId} {
      allow read: if signedIn() && canAccessArea(resource.data.areaId);
      allow create: if signedIn()
        && canAccessArea(request.resource.data.areaId)
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.teacherEmail == userEmail();
      allow update: if signedIn()
        && canAccessArea(resource.data.areaId)
        && canAccessArea(request.resource.data.areaId)
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.teacherEmail == userEmail();
    }

    match /attendanceSessions/{attendanceId} {
      allow read: if signedIn() && canAccessArea(resource.data.areaId);
      allow create: if signedIn()
        && canAccessArea(request.resource.data.areaId)
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.teacherEmail == userEmail();
      allow update: if signedIn()
        && canAccessArea(resource.data.areaId)
        && canAccessArea(request.resource.data.areaId)
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.teacherEmail == userEmail();
    }

    match /classLogs/{logId} {
      allow read: if signedIn() && canAccessArea(resource.data.areaId);
      allow create: if signedIn()
        && canAccessArea(request.resource.data.areaId)
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.teacherEmail == userEmail();
      allow update: if signedIn()
        && canAccessArea(resource.data.areaId)
        && canAccessArea(request.resource.data.areaId)
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.teacherEmail == userEmail();
    }
  }
}
